<!DOCTYPE html>
<html>
<head>
  <title>Plant Health Monitor</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Firebase -->
  <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
  <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>

  <!-- Chart -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #f4f6f8;
    }

    h2 { color: green; }

    .card {
      background: white;
      padding: 15px;
      margin: 15px auto;
      width: 90%;
      max-width: 400px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .healthy   { color: green; font-weight: bold; }
    .unhealthy { color: red;   font-weight: bold; }

    canvas {
      max-width: 90%;
      margin: 20px auto;
    }

    /* ── Floating button ── */
    .chat-toggle {
    position: fixed !important;
    bottom: 20px !important;
    right: 20px !important;
    width: 80px !important;
    height: 80px !important;
    background: red !important;
    color: white !important;
    z-index: 999999 !important;
    border-radius: 50% !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    font-size: 40px !important;
}

    /* ── Chat window ── */
    .chat-container {
      position: fixed;
      bottom: 100px;
      right: 25px;
      width: 380px;
      height: 550px;
      background: white;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
      display: none;          /* hidden by default */
      flex-direction: column;
      overflow: hidden;
      z-index: 9999;
    }

    .chat-header {
      background: #27ae60;
      color: white;
      padding: 18px;
      font-size: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .chat-header span { cursor: pointer; font-size: 22px; }

    .chat-box {
      flex: 1;
      padding: 15px;
      overflow-y: auto;
      background: #f7fff8;
    }

    .chat-input {
      display: flex;
      border-top: 1px solid #ddd;
    }

    .chat-input input {
      flex: 1;
      padding: 15px;
      border: none;
      outline: none;
    }

    .chat-input button {
      background: #27ae60;
      color: white;
      border: none;
      padding: 15px 20px;
      cursor: pointer;
    }

    /* ── Messages ── */
    .message {
      max-width: 80%;
      padding: 10px 14px;
      border-radius: 18px;
      margin-bottom: 10px;
      font-size: 14px;
      line-height: 1.5;
      word-wrap: break-word;
    }

    .message.user {
      background: #27ae60;
      color: white;
      border-bottom-right-radius: 4px;
      margin-left: auto;
      text-align: right;
    }

    .message.bot {
      background: #e8f5e9;
      color: #1b5e20;
      border-bottom-left-radius: 4px;
      margin-right: auto;
      text-align: left;
    }
  </style>
</head>

<body>
<h2>🌱 Smart Plant Monitor</h2>

<div class="card">
  <p>Soil Moisture: <span id="soil">--</span>%</p>
  <p>Temperature: <span id="temp">--</span> °C</p>
  <p>Humidity: <span id="hum">--</span>%</p>
</div>

<div class="card">
  <h3 id="health">Plant Health: --</h3>
  <p>Last Updated: <span id="time">--</span></p>
</div>

<canvas id="moistureChart"></canvas>
<canvas id="tempChart"></canvas>

<!-- ── Floating Chat Button (ONCE) ── -->
<div class="chat-toggle" onclick="toggleChat()">🌱</div>

<!-- ── Chat Window (ONCE) ── -->
<div class="chat-container" id="chatContainer">
  <div class="chat-header">
    Plant AI Assistant
    <span onclick="toggleChat()">✖</span>
  </div>
  <div class="chat-box" id="chatBox"></div>
  <div class="chat-input">
    <input type="text" id="userInput" placeholder="Ask about your plant...">
    <button onclick="sendMessage()">Send</button>
  </div>
</div>


<script>
/* ================================================
   FIREBASE
================================================ */
const firebaseConfig = {
  apiKey: "",
  authDomain: "",
  databaseURL: "",
  projectId: "",
  storageBucket: "",
  messagingSenderId: "",
  appId: ""
};
const API_KEY = "";
firebase.initializeApp(firebaseConfig);
const db = firebase.database();

/* ================================================
   CHARTS
================================================ */
let labels       = [];
let moistureData = [];
let tempData     = [];

const moistureChart = new Chart(document.getElementById("moistureChart"), {
  type: "line",
  data: {
    labels,
    datasets: [{ label: "Soil Moisture (%)", data: moistureData, borderColor: "blue", fill: false }]
  }
});

const tempChart = new Chart(document.getElementById("tempChart"), {
  type: "line",
  data: {
    labels,
    datasets: [{ label: "Temperature (°C)", data: tempData, borderColor: "orange", fill: false }]
  }
});

/* ================================================
   SENSOR DATA LISTENER
================================================ */
db.ref("sensor_data").limitToLast(20).on("value", snapshot => {
  const data = snapshot.val();
  if (!data) return;

  const values = Object.values(data);
  values.sort((a, b) => (a.timestamp || 0) - (b.timestamp || 0));

  const latest = values[values.length - 1];

  document.getElementById("soil").innerText = latest.soil_moisture_percent ?? "--";
  document.getElementById("temp").innerText = latest.temperature ?? "--";
  document.getElementById("hum").innerText  = latest.humidity ?? "--";

  labels.length = 0;
  moistureData.length = 0;
  tempData.length = 0;

  values.forEach(d => {
    labels.push(d.timestamp || "--");
    moistureData.push(d.soil_moisture_percent || 0);
    tempData.push(d.temperature || 0);
  });

  moistureChart.update();
  tempChart.update();
});

/* ================================================
   AI OUTPUT LISTENER
================================================ */
db.ref("ai_output").on("value", snapshot => {
  const d = snapshot.val();
  if (!d) return;

  const healthEl = document.getElementById("health");
  healthEl.innerText = "Plant Health: " + (d.plant_health || "--");
  healthEl.className = d.plant_health === "Healthy" ? "healthy" : "unhealthy";
  document.getElementById("time").innerText = d.last_updated || new Date().toLocaleString();
});


// Run every 5 seconds
setInterval(checkDeviceStatus, 5000);

// Run immediately on page load
checkDeviceStatus();
/* ================================================
   CHATBOT
================================================ */


function toggleChat() {
  const chat = document.getElementById("chatContainer");
  chat.style.display = (chat.style.display === "flex") ? "none" : "flex";
}

function addMessage(text, sender) {
  const chatBox = document.getElementById("chatBox");
  const msg = document.createElement("div");
  msg.className = `message ${sender}`;
  msg.innerText = text;
  chatBox.appendChild(msg);
  chatBox.scrollTop = chatBox.scrollHeight;
}

async function getSensorData() {
  try {
    const snapshot = await db.ref("sensor_data").limitToLast(1).once("value");
    if (!snapshot.exists()) return null;
    const data = snapshot.val();
    const latest = data[Object.keys(data)[0]];
    return {
      moisture:    latest.soil_moisture_percent || 0,
      temperature: latest.temperature || 0,
      humidity:    latest.humidity || 0,
      timestamp:   latest.timestamp || "Unknown"
    };
  } catch (err) {
    console.error("Firebase Error:", err);
    return null;
  }
}

async function getAIResponse(userText) {
  try {
    const sensorData = await getSensorData();
    let sensorContext = "";

    if (sensorData) {
      sensorContext = `Current Plant Sensor Readings:
- Soil Moisture: ${sensorData.moisture}%
- Temperature: ${sensorData.temperature}°C
- Humidity: ${sensorData.humidity}%
- Last Updated: ${sensorData.timestamp}
`;
    }

  const response = await fetch(
  "https://openrouter.ai/api/v1/chat/completions",
  {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${API_KEY}`,
      "Content-Type": "application/json",
      "HTTP-Referer": window.location.href,
      "X-Title": "Plant AI Assistant"
    },
    body: JSON.stringify({
      model: "openai/gpt-oss-120b:free",
      messages: [
        {
          role: "system",
          content:
            "You are a smart plant assistant that uses realtime sensor data."
        },
        {
          role: "user",
          content: `${sensorContext}\n${userText}`
          
        }
      ]
    })
  }
);
console.log(await response.clone().json());



    const data = await response.json();
    if (data.choices && data.choices.length > 0) return data.choices[0].message.content;
    if (data.error) return "API Error: " + data.error.message;
    return "No response from AI 😓";

  } catch (err) {
    console.error(err);
    return "Error connecting to AI 😓";
  }
}

async function sendMessage() {
  const input    = document.getElementById("userInput");
  const userText = input.value.trim();
  if (!userText) return;

  addMessage(userText, "user");
  input.value = "";
  addMessage("🌿 Thinking...", "bot");

  const aiReply = await getAIResponse(userText);

  const chatBox = document.getElementById("chatBox");
  chatBox.removeChild(chatBox.lastChild);   // remove "Thinking..."
  addMessage(aiReply, "bot");
}

/* ================================================
   INIT  (single load event)
================================================ */
window.addEventListener("load", () => {
  document.getElementById("userInput").addEventListener("keypress", e => {
    if (e.key === "Enter") sendMessage();
  });

  addMessage("Hi! I'm your Plant AI Assistant 🌱\nAsk me anything about your plant!", "bot");
});
</script>
<div class="chat-toggle" onclick="toggleChat()">🌱</div>

<div class="chat-container" id="chatContainer">
    <div class="chat-header">
        Plant AI Assistant
        <span onclick="toggleChat()">✖</span>
    </div>

    <div class="chat-box" id="chatBox"></div>

    <div class="chat-input">
        <input type="text" id="userInput" placeholder="Ask about your plant...">
        <button onclick="sendMessage()">Send</button>
    </div>
</div>

</body>
</html>
